# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here   # e.g. -1001234567890 for a group

# Google Ads — test account ID (format: 123-456-7890)
GOOGLE_ADS_CUSTOMER_ID=955-234-8691

# Google Ads OAuth credentials (used by google-ads library via env vars)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
# Optional: only needed if using a Manager (MCC) account
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_manager_account_id

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
